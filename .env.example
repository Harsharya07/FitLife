# FitLife AI Configuration
# Copy this file to .env in the project root and fill in your API key.

# Provider: gemini | openai
LLM_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI-compatible APIs (optional alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# App security (change in production)
SECRET_KEY=fitlife-dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin user — signup with this username gets admin access
ADMIN_USERNAME=admin

# AI rate limiting
AI_RATE_LIMIT_REQUESTS=20
AI_RATE_LIMIT_WINDOW_SECONDS=60

# Set to production in deployed environments
# FITLIFE_ENV=production
